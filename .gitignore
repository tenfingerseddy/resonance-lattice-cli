experiments/kaggle/build_cartridge/dataset/checkpoint.pt
build_distill_only.log
build_e5.log

# Backbone comparison artifacts (large binaries)
experiments/embeddings/
experiments/checkpoints/backbone_comparison/*.pt

# Claude Code worktrees (auto-created, can be very large)
.claude/worktrees/

# ONNX exported backbones (large binaries, rebuild with encoder_onnx.export_backbone_onnx)
onnx_backbone/
*_onnx/

# BEIR benchmark data (downloaded datasets) and build cache
beir_data/
benchmarks/results/beir/scifact_cache/

# Benchmark caches (cloned repos, cartridges, primers)
benchmarks/.primer_cache/
benchmarks/.bakeoff_cache/

# Large experiment checkpoints (binary, reproduce via training)
experiments/checkpoints/phase3_*/
experiments/checkpoints/semantic_heads/*.pt

# Large Kaggle artifacts (datasets, outputs, training data)
experiments/kaggle/fabric-docs-dataset/
experiments/kaggle/beir_benchmark/output/
experiments/kaggle/training_data/
experiments/kaggle/phase4_*/

# Kaggle working directories (kernels, uploads, outputs, training data)
# All consolidated under kaggle/ — only committed subdirs (e.g. kaggle/kernel)
# are tracked; everything else is local build/output scratch.
kaggle/bench/
kaggle/bench_kernel/
kaggle/upload/
kaggle/output/
kaggle/ternary/
kaggle/job_chunking/
kaggle/longmemeval/rlat_*.tar.gz
kaggle/longmemeval-outputs/
kaggle/training_data.jsonl

# Training checkpoints (large binaries, reproduce via Kaggle runs)
checkpoints/

# Intermediate benchmark results (keep final results in committed JSON)
benchmarks/results/retrieval_gate/gate_*.json
benchmarks/results/longmemeval/*
!benchmarks/results/longmemeval/v14_full500_800.json
!benchmarks/results/longmemeval/kaggle_v15_phase1_e5/
!benchmarks/results/longmemeval/kaggle_v15_phase1_e5/**
!benchmarks/results/longmemeval/runpod_v15_bge/
!benchmarks/results/longmemeval/runpod_v15_bge/**

# BEIR sweep transcripts (large, regenerable; keep aggregate + per-corpus JSONs)
benchmarks/results/beir/new_arch/**/sweep*.log

# Direction docs (strategic analysis, not code — track selectively)
docs/direction/

# Claude Code internal state
.claude/scheduled_tasks.lock
.claude/skills/skill-creator/

# Website dev logs
website/devserver.err
website/devserver.log

# Sync scripts (local automation)
scripts/sync-public.sh

# Kaggle source tarballs (regenerate via `git archive`)
kaggle/**/*.tar.gz
resonance_lattice_src.tar.gz

# Kaggle dataset staging dirs (regenerable by copy from src/ and benchmarks/)
kaggle/longmemeval-dataset-v*/
kaggle/*-dataset-v*/

# LoCoMo benchmark data (auto-downloaded by bench_locomo.py from
# snap-research/locomo). 2.8MB, not worth tracking.
benchmarks/data/locomo/

# Benchmark working dirs (regenerable via benchmarks/extract_beir.py + rlat build)
/benchmark_data/
/bench_out/
