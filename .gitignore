# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Cython build artifacts (generated by setup.py build_ext)
src/resonance_lattice/**/*.c
src/resonance_lattice/**/*.so
src/resonance_lattice/**/*.pyd

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
.claude/settings.local.json
.mcp.json

# Data (downloaded datasets — large)
data/
*.rlat

# Layered-memory root (user-specific conversation history; regenerable via
# scripts/ingest_claude_transcripts.py). .rlat is already covered above,
# but the sidecar .db and _ingested_sessions.json contain raw prompts.
memory/
.claude/memory-primer.md

# Local caches / scratch outputs (not committed)
.cache/
cartridges/
outputs/
**/*_tl_cache/

# Experiment logs (track selectively)
experiments/logs/

# Remote-GPU orchestrator local state (pod ids, ssh artifacts, logs)
# Glob covers .runpod_state.json (legacy single-file) and per-orchestrator
# variants like .runpod_state_stage1_eval.json, .runpod_state_stage2.json.
scripts/runpod/.runpod_state*.json
scripts/runpod/logs/
scripts/lambda/.lambda_state*.json
scripts/lambda/logs/

# OS
.DS_Store
Thumbs.db

# Rust
rust/target/

# Profiling
*.prof
*.lprof

# Jupyter
.ipynb_checkpoints/
notebooks/resonance_lattice_embeddings/*.npy
notebooks/resonance_lattice_embeddings.zip
experiments/checkpoints/gated_residual/
experiments/checkpoints/reaction_diffusion/
experiments/ws4/results/*.pt

# Large experiment data (track selectively)
notebooks/resonance_lattice_embeddings/metadata_expanded50.json
experiments/phase5/distillation_v2.json
experiments/phase5/distillation_v2_partial.json
experiments/kaggle/data_v2/distillation_qa.json

