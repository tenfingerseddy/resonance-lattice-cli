{
	"compilerOptions": {
		"baseUrl": ".",
		"outDir": "./dist",
		"target": "ES2018",
		"module": "ESNext",
		"moduleResolution": "node",
		"lib": ["ES2018", "DOM"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"declaration": false,
		"sourceMap": true,
		"noEmit": true
	},
	"include": ["src/**/*.ts"]
}
